# 사용 안내
# 1. 이 파일을 .env로 복사하세요
# 2. 모든 플레이스홀더를 실제 값으로 교체하세요
# 3. .env 파일이 버전 관리에 커밋되지 않도록 하세요

# ========== 이미지 버전 ==========
# WeKnora 이미지 버전 태그, 선택 값: latest(안정판), main(최신 개발판)
# WEKNORA_VERSION=latest

# gin 모드
# 선택 값: debug(개발 모드, 상세 로그), release(운영 모드, Swagger 문서 비활성화)
GIN_MODE=release

# 로그 레벨, 선택 값: debug, info, warn, error, fatal, 기본값 debug
# LOG_LEVEL=debug

# 신규 사용자 등록 금지(운영 환경은 true 권장)
DISABLE_REGISTRATION=false

# Ollama 서비스 기본 URL, 로컬/다른 서버에서 실행 중인 Ollama 서비스 연결에 사용
OLLAMA_BASE_URL=http://host.docker.internal:11434

# 스토리지 설정
# 기본 데이터베이스 유형(postgres/mysql)
DB_DRIVER=postgres

# 벡터 스토리지 유형(postgres/elasticsearch_v7/elasticsearch_v8/qdrant/milvus/weaviate)
RETRIEVE_DRIVER=postgres

# 파일 스토리지 유형(local/minio/cos/tos/s3)
STORAGE_TYPE=local

# 스트림 처리 백엔드(memory/redis)
STREAM_MANAGER_TYPE=redis

# 앱 서비스 호스트명, 기본값 app(Docker 내부 서비스명)
# 원격 백엔드로 프록시하려면 remote-app.example.com 같은 원격 주소로 설정하세요
APP_HOST=app

# 앱 서비스 호스트 매핑 포트, 기본값 8080(호스트 접근에만 영향, 컨테이너 간 통신에는 영향 없음)
APP_PORT=8080

# NGINX가 백엔드로 프록시하는 대상 포트, 기본값 8080(App 컨테이너 내부 리스닝 포트)
# 로컬 배포: 기본값 유지, APP_PORT와 함께 변경할 필요 없음
# 원격 배포: 원격 App 서비스의 실제 포트로 설정
# APP_BACKEND_PORT=8080

# NGINX가 백엔드로 프록시하는 프로토콜, 기본값 http
# 원격 배포에서 백엔드가 HTTPS이면 https로 설정
# APP_SCHEME=http

# 프론트엔드 서비스 포트, 기본값 80
FRONTEND_PORT=80

# 문서 파싱 모듈 포트, 기본값 50051
DOCREADER_PORT=50051

# 데이터베이스 호스트 (개발 모드: localhost, 프로덕션: postgres)
DB_HOST=localhost

# 데이터베이스 포트
DB_PORT=5432

# 데이터베이스 사용자명
DB_USER=postgres

# 데이터베이스 비밀번호
DB_PASSWORD=postgres123!@#

# 데이터베이스 이름
DB_NAME=WeKnora

# redis를 스트림 처리 백엔드로 사용하면 아래 파라미터를 설정하세요
# Redis 사용자명, Redis 6.0+ ACL 기능 지원(선택)
# REDIS_USERNAME=

# Redis 비밀번호, 비밀번호가 없으면 비워도 됩니다
REDIS_PASSWORD=redis123!@#

# Redis DB 인덱스, 기본값 0
REDIS_DB=0

# Redis 키 접두사, 네임스페이스 분리에 사용
REDIS_PREFIX=stream:

# 로컬 스토리지를 사용할 때 파일 저장 기본 디렉터리 경로
LOCAL_STORAGE_BASE_DIR=/data/files

# 더티 데이터 자동 복구 여부
AUTO_RECOVER_DIRTY=true

TENANT_AES_KEY=weknorarag-api-key-secret-secret

# AES-256 키, 데이터베이스의 API Key 등 민감 필드 암호화에 사용(반드시 32바이트)
SYSTEM_AES_KEY=weknora-system-aes-key-32bytes!!

# 지식 그래프 구축/검색 활성화 여부(구축 단계에서 LLM 호출로 시간이 오래 걸림)
ENABLE_GRAPH_RAG=false


# JWT_SECRET 설정, 프론트엔드 로그인 토큰 갱신에 사용
JWT_SECRET=weknora-jwt-secret

# MinIO 포트
# MINIO_PORT=9000

# MinIO 콘솔 포트
# MINIO_CONSOLE_PORT=9001

# Embedding 동시성 수, 429 오류가 나면 이 값을 줄이세요
CONCURRENCY_POOL_SIZE=5

# (Removed: IMAGE_MAX_CONCURRENT, OCR_BACKEND — Go App 모듈로 이동됨)

# ElasticSearch를 벡터 스토리지로 사용하면 아래 파라미터를 설정하세요
# ElasticSearch 주소, 예: http://localhost:9200
# ELASTICSEARCH_ADDR=your_elasticsearch_addr

# ElasticSearch 사용자명, 인증이 필요할 때 사용
# ELASTICSEARCH_USERNAME=your_elasticsearch_username

# ElasticSearch 비밀번호, 인증이 필요할 때 사용
# ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# ElasticSearch 인덱스 이름, 벡터 데이터 저장에 사용
# ELASTICSEARCH_INDEX=WeKnora

# Qdrant를 벡터 스토리지로 사용하면 아래 파라미터를 설정하세요
# Qdrant 서비스 호스트 주소
# QDRANT_HOST=localhost

# Qdrant 서비스 포트
# QDRANT_PORT=6334

# Qdrant 컬렉션 이름, 벡터 데이터 저장에 사용
# QDRANT_COLLECTION=weknora_embeddings

# Qdrant API 키, 인증이 필요할 때(선택)
# QDRANT_API_KEY=your_qdrant_api_key

# TLS 암호화 연결 사용 여부(선택, 기본값 false)
# QDRANT_USE_TLS=false

# MinIO를 파일 스토리지로 사용하면 아래 파라미터를 설정하세요
# MinIO 액세스 키
# MINIO_ACCESS_KEY_ID=your_minio_access_key

# MinIO 시크릿 키
# MINIO_SECRET_ACCESS_KEY=your_minio_secret_key

# MinIO 버킷 이름, 파일 저장에 사용
# MINIO_BUCKET_NAME=your_minio_bucket_name

# Tencent Cloud COS를 파일 스토리지로 사용하면 아래 파라미터를 설정하세요
# Tencent Cloud COS 액세스 키 ID
# COS_SECRET_ID=your_cos_secret_id

# Tencent Cloud COS 시크릿 키
# COS_SECRET_KEY=your_cos_secret_key

# Tencent Cloud COS 리전, 예: ap-guangzhou
# COS_REGION=your_cos_region

# Tencent Cloud COS 버킷 이름
# COS_BUCKET_NAME=your_cos_bucket_name

# Tencent Cloud COS 앱 ID
# COS_APP_ID=your_cos_app_id

# Tencent Cloud COS 경로 접두사, 파일 저장에 사용
# COS_PATH_PREFIX=your_cos_path_prefix

# COS_ENABLE_OLD_DOMAIN=true는旧 도메인 형식 사용을 의미하며, 기본값 true
COS_ENABLE_OLD_DOMAIN=true

# Volcano Engine TOS를 파일 스토리지로 사용하면 아래 파라미터를 설정하세요
# TOS 액세스 엔드포인트, 예: https://tos-cn-beijing.volces.com
# TOS_ENDPOINT=https://tos-cn-beijing.volces.com

# TOS 리전, 예: cn-beijing
# TOS_REGION=cn-beijing

# TOS 액세스 키 Access Key
# TOS_ACCESS_KEY=your_tos_access_key

# TOS 시크릿 키 Secret Key
# TOS_SECRET_KEY=your_tos_secret_key

# TOS 버킷 이름
# TOS_BUCKET_NAME=your_tos_bucket_name

# TOS 경로 접두사(선택)
# TOS_PATH_PREFIX=your_tos_path_prefix

# TOS 임시 버킷 이름(선택, 자동 만료 임시 파일 저장용)
# TOS_TEMP_BUCKET_NAME=your_tos_temp_bucket_name

# TOS 임시 버킷 리전(선택, 기본값은 메인 버킷과 동일)
# TOS_TEMP_REGION=your_tos_temp_region

# AWS S3를 파일 스토리지로 사용하면 아래 파라미터를 설정하세요
# AWS S3 액세스 엔드포인트, 예: https://s3.amazonaws.com
# S3_ENDPOINT=https://s3.amazonaws.com

# AWS S3 리전, 예: us-east-1
# S3_REGION=us-east-1

# AWS S3 액세스 키 Access Key
# S3_ACCESS_KEY=your_s3_access_key

# AWS S3 시크릿 키 Secret Key
# S3_SECRET_KEY=your_s3_secret_key

# AWS S3 버킷 이름
# S3_BUCKET_NAME=your_s3_bucket_name

# AWS S3 경로 접두사(선택)
# S3_PATH_PREFIX=your_s3_path_prefix

# 네트워크 연결에 Web 프록시를 사용하면 아래 파라미터를 설정하세요
# WEB_PROXY=your_web_proxy

# Neo4j 토글
# NEO4J_ENABLE=false

# Neo4j 접속 주소
# NEO4J_URI=neo4j://neo4j:7687

# Neo4j 사용자명과 비밀번호
# NEO4J_USERNAME=neo4j

# Neo4j 비밀번호
# NEO4J_PASSWORD=password

# ========== 파일 업로드 크기 제한 ==========
# 통합 파일 크기 제한(MB), 기본값 50MB
# 영향: 단일 파일 업로드, gRPC 메시지 크기, Nginx 요청 본문 크기
# MAX_FILE_SIZE_MB=50

# ========== Agent Skills Sandbox 설정 ==========
# Sandbox 모드: docker(기본값), local, disabled
WEKNORA_SANDBOX_MODE=docker

# 스크립트 실행 타임아웃(초), 기본값 60
WEKNORA_SANDBOX_TIMEOUT=60

# 사용자 정의 Sandbox Docker 이미지
WEKNORA_SANDBOX_DOCKER_IMAGE=wechatopenai/weknora-sandbox:latest

# APK 미러 소스 설정(선택)
APK_MIRROR_ARG=mirrors.tencent.com

# 如果使用Milvus作为向量存储，需要配置以下参数
# Milvus服务地址
# MILVUS_ADDRESS=milvus:19530

# Milvus集合名称，用于存储向量数据
# MILVUS_COLLECTION=weknora_embeddings

# Milvus 用户名(可选）
# MILVUS_USERNAME=your_milvus_username

# Milvus 密码(可选）
# MILVUS_PASSWORD=your_milvus_password

# Milvus 数据库名称(可选）
# MILVUS_DB_NAME=your_milvus_db_name

# Docreader 地址
DOCREADER_ADDR=docreader:50051

# Docreader 连接方式
DOCREADER_TRANSPORT=grpc

# 如果使用Weaviate作为向量存储，需要配置以下参数
# 注意：容器内访问请使用 service:port（不要用 localhost，也不要用宿主机映射端口）
# Weaviate HTTP 地址（Docker 内：weaviate:8080；宿主机访问：localhost:9035）
# WEAVIATE_HOST=weaviate:8080

# Weaviate gRPC 地址（Docker 内：weaviate:50051；宿主机访问：localhost:50052）
# WEAVIATE_GRPC_ADDRESS=weaviate:50051

# Weaviate 架构模式
# WEAVIATE_SCHEME=http

# 是否开启认证（如果你在 weaviate 里启用了 APIKey/OIDC 认证，再把这里设为 true 并配置 WEAVIATE_API_KEY）
# WEAVIATE_AUTH_ENABLED=false

# API Key(可选)
# WEAVIATE_API_KEY=your_secret_key

# Weaviate 数据库名称(可选）
#WEAVIATE_COLLECTION=your_weaviate_db_name
